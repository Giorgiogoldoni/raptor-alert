name: 🦅 RAPTOR Alert - Aggiorna dati ETF

on:
  schedule:
    - cron: '0 * * * *'   # ogni ora esatta (UTC)
  workflow_dispatch:        # avvio manuale dal pannello GitHub

jobs:
  update-etf-data:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Scarica dati ETF da Yahoo Finance
        run: python fetch_data.py

      - name: Commit e push data/etf.json
        run: |
          git config user.name "raptor-bot"
          git config user.email "raptor-bot@github.com"
          git add data/etf.json
          git diff --staged --quiet || git commit -m "🦅 Update ETF data - $(date -u '+%Y-%m-%d %H:%M UTC')"
          git push
